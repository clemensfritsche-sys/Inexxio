# ============================================================
# INEXXIO ENTERPRISE CENTRAL SYSTEM - Environment Variables
# ============================================================
# Kopiere diese Datei nach .env.local und fülle alle Felder aus.
# NIEMALS .env.local in Git committen!

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
DEBUG=true

# ─── Database ────────────────────────────────────────────────
# Lokal: postgresql://postgres:postgres@localhost:5432/inexxio_local
# Cloud SQL (Production): postgresql://user:pass@/dbname?host=/cloudsql/project:region:instance
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inexxio_local

# ─── Firebase Authentication ────────────────────────────────
# Aus Firebase Console: Projekteinstellungen > Allgemein
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=inexxio.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=inexxio
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=inexxio.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Backend: Service Account JSON (Pfad zur Datei oder JSON-String)
FIREBASE_PROJECT_ID=inexxio
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ─── Backend API ──────────────────────────────────────────────
# Lokale Entwicklung: http://localhost:8000
# Production: https://api.inexxio.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Security ────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# ─── Google Cloud Storage ────────────────────────────────────
GCS_BUCKET=inexxio-uploads
GOOGLE_CLOUD_PROJECT=inexxio

# ─── Stripe (Phase 2) ────────────────────────────────────────
# Aus Stripe Dashboard: Developers > API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (Gmail API) ────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_FROM=info.inexxio@gmail.com

# ─── hCaptcha ────────────────────────────────────────────────
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# ─── Analytics (Plausible) ───────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=inexxio.com

# ─── Claude API (Anthropic) ──────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Typesense (Phase 2) ─────────────────────────────────────
TYPESENSE_API_KEY=
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://inexxio.web.app,https://inexxio.com
