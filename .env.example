# ============================================================
# INEXXIO – Environment Variables Template
# Copy to .env.local and fill in values. NEVER commit .env.local
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://inexxio:password@localhost:5432/inexxio_local
DATABASE_URL_SYNC=postgresql://inexxio:password@localhost:5432/inexxio_local

# --- Firebase ---
FIREBASE_PROJECT_ID=inexxio-dev
FIREBASE_SERVICE_ACCOUNT_KEY={}  # JSON string from Firebase Console

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=inexxio-dev
GOOGLE_CLOUD_REGION=europe-west6
GCS_BUCKET_NAME=inexxio-dev-storage

# --- Gmail API ---
GMAIL_CREDENTIALS={}  # JSON string
GMAIL_SENDER=info.inexxio@gmail.com

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Typesense ---
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=inexxio-dev-key

# --- hCaptcha ---
HCAPTCHA_SECRET_KEY=...
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=...

# --- Plausible Analytics ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=inexxio.web.app

# --- App ---
APP_ENV=development  # development | staging | production
SECRET_KEY=change-me-in-production-min-32-chars
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# --- Next.js Public ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=inexxio-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=inexxio-dev
NEXT_PUBLIC_APP_URL=http://localhost:3000
